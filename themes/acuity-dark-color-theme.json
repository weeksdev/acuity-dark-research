  "tokenColors": [
    {
      "name": "Default foreground",
      "scope": [
        "source",
        "text",
        "variable",
        "variable.other",
        "meta.embedded"
      ],
      "settings": {
        "foreground": "#CBD3D8"
      }
    },
    {
      "name": "Comments and documentation",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.quoted.docstring",
        "comment.block.documentation",
        "comment.line.documentation"
      ],
      "settings": {
        "foreground": "#8696A0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords and storage",
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#D5A351"
      }
    },
    {
      "name": "Control-flow keywords \u2014 redundant bold cue",
      "scope": [
        "keyword.control",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.flow",
        "keyword.control.return",
        "keyword.control.exception",
        "keyword.control.import",
        "keyword.control.export"
      ],
      "settings": {
        "foreground": "#D5A351",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated",
        "punctuation.definition.string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#4ACFB5"
      }
    },
    {
      "name": "Escape sequences",
      "scope": [
        "constant.character.escape",
        "constant.character.format.placeholder",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#D5A351",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Numbers, booleans, enum-like constants",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.other",
        "variable.other.constant",
        "support.constant",
        "entity.name.constant"
      ],
      "settings": {
        "foreground": "#E3B8EC"
      }
    },
    {
      "name": "Functions and methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function",
        "meta.function-call entity.name.function",
        "meta.method-call entity.name.function"
      ],
      "settings": {
        "foreground": "#AECC8C"
      }
    },
    {
      "name": "Types, classes, structs, interfaces, namespaces",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.struct",
        "entity.name.interface",
        "entity.name.enum",
        "entity.name.namespace",
        "support.type",
        "support.class",
        "storage.type.class",
        "storage.type.interface",
        "storage.type.struct",
        "storage.type.enum"
      ],
      "settings": {
        "foreground": "#70AFE8"
      }
    },
    {
      "name": "Type parameters",
      "scope": [
        "entity.name.type.type-parameter",
        "meta.type.parameters entity.name.type"
      ],
      "settings": {
        "foreground": "#70AFE8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Attributes, annotations, decorators",
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator",
        "meta.annotation",
        "entity.other.attribute-name",
        "support.type.attribute"
      ],
      "settings": {
        "foreground": "#E3B8EC",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Properties and fields",
      "scope": [
        "variable.other.property",
        "variable.other.member",
        "variable.other.field",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#CBD3D8"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "meta.parameters variable",
        "meta.function.parameters variable"
      ],
      "settings": {
        "foreground": "#CBD3D8"
      }
    },
    {
      "name": "Operators and punctuation remain neutral",
      "scope": [
        "keyword.operator",
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#AEB7BD"
      }
    },
    {
      "name": "Regular expressions",
      "scope": [
        "string.regexp",
        "constant.regexp",
        "keyword.operator.quantifier.regexp"
      ],
      "settings": {
        "foreground": "#AECC8C"
      }
    },
    {
      "name": "Markup headings",
      "scope": [
        "markup.heading",
        "entity.name.section",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#D5A351",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup links",
      "scope": [
        "markup.underline.link",
        "string.other.link",
        "meta.link",
        "markup.underline"
      ],
      "settings": {
        "foreground": "#4ACFB5",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markup bold",
      "scope": [
        "markup.bold",
        "punctuation.definition.bold"
      ],
      "settings": {
        "foreground": "#CBD3D8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup italic",
      "scope": [
        "markup.italic",
        "punctuation.definition.italic"
      ],
      "settings": {
        "foreground": "#CBD3D8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Inserted text",
      "scope": [
        "markup.inserted",
        "meta.diff.header.to-file"
      ],
      "settings": {
        "foreground": "#AECC8C"
      }
    },
    {
      "name": "Deleted text and invalid tokens",
      "scope": [
        "markup.deleted",
        "invalid",
        "invalid.illegal",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#F0A29A",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Changed text",
      "scope": [
        "markup.changed",
        "meta.diff.range"
      ],
      "settings": {
        "foreground": "#D5A351"
      }
    },
    {
      "name": "JSON property names",
      "scope": [
        "support.type.property-name.json",
        "meta.structure.dictionary.key.json string.quoted.double.json"
      ],
      "settings": {
        "foreground": "#70AFE8"
      }
    },
    {
      "name": "HTML/XML tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#D5A351"
      }
    },
    {
      "name": "CSS selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.name.tag.css"
      ],
      "settings": {
        "foreground": "#70AFE8"
      }
    },
    {
      "name": "CSS properties",
      "scope": [
        "support.type.property-name.css",
        "meta.property-name.css"
      ],
      "settings": {
        "foreground": "#CBD3D8"
      }
    },
    {
      "name": "C# class, struct, interface, enum, namespace names",
      "scope": [
        "entity.name.type.class.cs",
        "entity.name.type.struct.cs",
        "entity.name.type.interface.cs",
        "entity.name.type.enum.cs",
        "entity.name.namespace.cs",
        "support.type.cs"
      ],
      "settings": {
        "foreground": "#70AFE8"
      }
    },
    {
      "name": "C# methods and local functions",
      "scope": [
        "entity.name.function.cs",
        "entity.name.function.local.cs",
        "support.function.cs"
      ],
      "settings": {
        "foreground": "#AECC8C"
      }
    },
    {
      "name": "C# attributes",
      "scope": [
        "entity.name.type.attribute.cs",
        "meta.attribute.cs"
      ],
      "settings": {
        "foreground": "#E3B8EC",
        "fontStyle": "italic"
      }
    },
    {
      "name": "C# interpolation punctuation",
      "scope": [
        "punctuation.definition.interpolation.begin.cs",
        "punctuation.definition.interpolation.end.cs"
      ],
      "settings": {
        "foreground": "#D5A351",
        "fontStyle": "bold"
      }
    },
    {
      "name": "C# XML documentation tags",
      "scope": [
        "comment.block.documentation.cs entity.name.tag",
        "comment.block.documentation.cs entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#4ACFB5",
        "fontStyle": "italic"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#70AFE8",
